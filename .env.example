# Postgres connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taznee?schema=public"

# Auth.js (NextAuth) — generate with `openssl rand -base64 32`
NEXTAUTH_SECRET="replace-with-a-random-secret"

# Stripe test-mode keys (https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Public base URL of the app, used for Stripe redirect return_url etc.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
