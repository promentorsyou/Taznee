# Postgres connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taznee?schema=public"

# Auth.js (NextAuth) — generate with `openssl rand -base64 32`
NEXTAUTH_SECRET="replace-with-a-random-secret"

# Stripe test-mode keys (https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Public base URL of the app, used for Stripe redirect return_url etc.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# SEO indexing gate. Leave unset/false so the demo and staging stay noindex.
# Set to "true" ONLY at real launch (real photos, legal pages, live checkout).
# NEXT_PUBLIC_INDEXABLE="true"

# Public support email (used on contact points and in Organization schema).
# NEXT_PUBLIC_SUPPORT_EMAIL="care@taznee.com"

# Optional: live carrier shipping rates via EasyPost (https://www.easypost.com/).
# Leave EASYPOST_API_KEY unset to use the static weight/zone rate table in
# lib/shipping-data.ts instead — checkout works fully either way.
# EASYPOST_API_KEY="EZTKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# SHIP_FROM_NAME="Taznee Fulfillment"
# SHIP_FROM_STREET1="123 Example Rd"
# SHIP_FROM_CITY="Dhaka"
# SHIP_FROM_STATE=""
# SHIP_FROM_ZIP="1000"
# SHIP_FROM_COUNTRY="BD"
# SHIP_FROM_PHONE="+8801XXXXXXXXX"
