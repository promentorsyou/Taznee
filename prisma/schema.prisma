// Taznee — Prisma schema
// All monetary values are stored as integer cents (USD). Never use
// Float/Decimal for currency — see lib/money.ts for arithmetic helpers.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth / Users ----------

enum Role {
  CUSTOMER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  addresses Address[]
  cart      Cart?
  wishlist  Wishlist?
  orders    Order[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  fullName   String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String   @default("US")
  phone      String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
}

// ---------- Catalog ----------

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())

  products Product[]
}

model Designer {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  bio       String?
  location  String?
  createdAt DateTime @default(now())

  products Product[]
}

model Product {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String
  categoryId  String
  designerId  String?

  // integer cents, USD
  basePriceCents Int
  compareAtCents Int?

  // delivery-estimate inputs
  readyToShip       Boolean @default(false)
  processingMinDays Int     @default(3)
  processingMaxDays Int     @default(7)
  transitMinDays    Int     @default(5)
  transitMaxDays    Int     @default(9)

  weightGrams Int      @default(500)
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category         @relation(fields: [categoryId], references: [id])
  designer Designer?        @relation(fields: [designerId], references: [id])
  images   ProductImage[]
  variants ProductVariant[]
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  altText   String?
  position  Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id         String @id @default(cuid())
  productId  String
  size       String
  color      String
  sku        String @unique
  priceCents Int?

  inventory     Inventory?
  cartItems     CartItem[]
  wishlistItems WishlistItem[]
  orderItems    OrderItem[]

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  // NOTE: Product is reachable via this relation for Cart/Order/Wishlist items,
  // so those child models only store a variantId, not a duplicate productId.

  @@unique([productId, size, color])
}

model Inventory {
  id        String @id @default(cuid())
  variantId String @unique
  quantity  Int    @default(0)

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

// ---------- Cart / Wishlist ----------

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  variantId String
  quantity  Int    @default(1)

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
}

model Wishlist {
  id     String @id @default(cuid())
  userId String @unique

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WishlistItem[]
}

model WishlistItem {
  id         String @id @default(cuid())
  wishlistId String
  variantId  String

  wishlist Wishlist       @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  variant  ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, variantId])
}

// ---------- Orders ----------

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  addressId String
  status    OrderStatus @default(PENDING)

  subtotalCents Int
  shippingCents Int
  taxCents      Int @default(0)
  totalCents    Int

  // delivery estimate snapshot at time of order
  estimatedDeliveryMinDays Int
  estimatedDeliveryMaxDays Int
  estimatedDeliveryMinDate DateTime
  estimatedDeliveryMaxDate DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User        @relation(fields: [userId], references: [id])
  address Address     @relation(fields: [addressId], references: [id])
  items   OrderItem[]
  payment Payment?
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  variantId String

  // snapshots at time of purchase
  nameSnapshot          String
  sizeSnapshot          String
  colorSnapshot         String
  priceCentsSnapshot    Int
  shippingCentsSnapshot Int
  quantity              Int @default(1)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model Payment {
  id                    String        @id @default(cuid())
  orderId               String        @unique
  stripePaymentIntentId String?       @unique
  amountCents           Int
  currency              String        @default("usd")
  status                PaymentStatus @default(PENDING)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ---------- Shipping ----------

model ShippingZone {
  id        String   @id @default(cuid())
  name      String   @unique
  countries String[] // ISO country codes, e.g. ["US"]

  rates ShippingRate[]
}

model ShippingRate {
  id             String @id @default(cuid())
  shippingZoneId String
  minWeightGrams Int
  maxWeightGrams Int
  rateCents      Int
  transitMinDays Int
  transitMaxDays Int

  zone ShippingZone @relation(fields: [shippingZoneId], references: [id], onDelete: Cascade)
}
